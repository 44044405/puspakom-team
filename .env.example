# Copy this file to ".env" and fill in real values. NEVER commit the real .env.

# Shared team passcode — everyone on the team enters this to open the dashboard.
ACCESS_CODE=change-this-team-passcode

# Optional: DeepSeek API key, ONLY if AI features get added later. Kept server-side.
DEEPSEEK_API_KEY=

# Port the server listens on (the host usually sets this automatically).
PORT=4000
